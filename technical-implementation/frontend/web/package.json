{
  "name": "nvoms-frontend",
  "version": "2.2.3",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "demo": "playwright test",
    "demo:auth": "playwright test tests/demo/auth-flow.demo.ts --output=test-results/auth",
    "demo:patients": "playwright test tests/demo/patient-registry.demo.ts --output=test-results/patients",
    "demo:patient-detail": "playwright test tests/demo/patient-detail.demo.ts --output=test-results/patient-detail",
    "demo:registration": "playwright test tests/demo/patient-registration.demo.ts --output=test-results/registration",
    "demo:immunizations": "playwright test tests/demo/immunizations.demo.ts --output=test-results/immunizations",
    "demo:surveillance": "playwright test tests/demo/surveillance.demo.ts --output=test-results/surveillance",
    "demo:risk-map": "playwright test tests/demo/risk-map.demo.ts --output=test-results/risk-map",
    "demo:defaulters": "playwright test tests/demo/defaulters.demo.ts --output=test-results/defaulters",
    "demo:self-service": "playwright test tests/demo/self-service.demo.ts --output=test-results/self-service",
    "demo:caregiver": "playwright test tests/demo/caregiver-portal.demo.ts --output=test-results/caregiver",
    "demo:videos": "find test-results -name '*.webm' -print | sort",
    "demo:publish-videos": "node scripts/publish-demo-videos.mjs",
    "demo:report": "playwright show-report"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/interaction": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@react-jvectormap/core": "^1.0.4",
    "@react-jvectormap/world": "^1.1.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.17",
    "apexcharts": "^4.7.0",
    "autoprefixer": "^10.4.22",
    "flatpickr": "^4.6.13",
    "next": "^16.2.4",
    "react": "^19.2.0",
    "react-apexcharts": "^1.8.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.0",
    "react-dropzone": "^14.3.8",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "1.59.1",
    "@svgr/webpack": "^8.1.0",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/react-transition-group": "^4.4.12",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "postcss": "8.5.10",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "@react-jvectormap/core": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    },
    "@react-jvectormap/world": {
      "react": "^16.8.0 || ^17 || ^18 || ^19",
      "react-dom": "^16.8.0 || ^17 || ^18 || ^19"
    }
  }
}
