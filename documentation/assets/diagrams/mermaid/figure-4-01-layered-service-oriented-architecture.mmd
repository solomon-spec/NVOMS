%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#5a6278",
    "primaryTextColor": "#2f3152",
    "secondaryColor": "#f8fbff",
    "tertiaryColor": "#eef4ff",
    "lineColor": "#40455d",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 36,
    "rankSpacing": 52,
    "htmlLabels": true
  }
}}%%
flowchart TD
    classDef actor fill:#ffffff,stroke:#7e90b6,color:#2f3152,stroke-width:1px
    classDef layer fill:#f8fbff,stroke:#5a6278,color:#2f3152,stroke-width:1px
    classDef service fill:#eef4ff,stroke:#4d6fb8,color:#24314f,stroke-width:1px
    classDef store fill:#ffffff,stroke:#d17a28,color:#7a4212,stroke-width:2px
    classDef external fill:#ffffff,stroke:#8f79c8,color:#3f2d73,stroke-width:1px

    hw[Health Worker]:::actor
    official[Public Health Official]:::actor
    admin[Administrator]:::actor
    caregiver[Caregiver]:::actor

    subgraph presentation["Presentation layer"]
        direction LR
        webPortal[Web Portal]:::service
        dashboard[Analytics Dashboard]:::service
        adminPanel[Admin Panel]:::service
        smsChannel[SMS Notification Channel]:::service
    end

    subgraph application["Application layer"]
        direction LR
        userSvc[User Management Service]:::service
        registrySvc[Patient Registry Service]:::service
        syncSvc[Offline Sync Service]:::service
        vaccinationSvc[Vaccination Tracking Service]:::service
        notificationSvc[Notification Service]:::service
        analyticsSvc[Analytics Service]:::service
        predictionSvc[Prediction Service]:::service
        reportingSvc[Reporting Service]:::service
        interopSvc[Interoperability Service]:::service
    end

    subgraph data["Data layer"]
        direction LR
        postgres[(PostgreSQL)]:::store
    end

    subgraph integration["Integration layer"]
        direction LR
        dhis2[DHIS2]:::external
        fhir[FHIR Server]:::external
        gateway[SMS Gateway]:::external
        weather[Weather API]:::external
    end

    hw --> webPortal
    official --> dashboard
    admin --> adminPanel
    caregiver --> smsChannel

    webPortal --> application
    dashboard --> application
    adminPanel --> application
    smsChannel --> application

    application --> data
    notificationSvc --> gateway
    predictionSvc --> weather
    interopSvc --> fhir
    interopSvc --> dhis2
