%%{init: {
  "theme": "base",
  "themeVariables": {
    "actorBkg": "#ffffff",
    "actorBorder": "#4d6fb8",
    "actorTextColor": "#2f3152",
    "signalColor": "#40455d",
    "signalTextColor": "#2f3152",
    "labelBoxBkgColor": "#eef4ff",
    "labelBoxBorderColor": "#8fa4d6",
    "labelTextColor": "#2f3152",
    "noteBkgColor": "#f8fbff",
    "noteBorderColor": "#c7d3f0",
    "sequenceNumberColor": "#2f3152",
    "fontFamily": "Arial, Helvetica, sans-serif"
  }
}}%%
sequenceDiagram
    autonumber
    actor HealthWorker as "Health Worker"
    participant OfflineCache as "Offline Cache (IndexedDB)"
    participant SyncService as "Offline Sync Service"
    participant Vaccination as "Vaccination Service"
    participant CentralDB as "Central Database"

    Note over HealthWorker,CentralDB: FR7-FR11: Offline Data Capture and Sync
    HealthWorker->>OfflineCache: Record dose and observation
    OfflineCache->>OfflineCache: Store record locally (status = pending)
    OfflineCache-->>HealthWorker: Save confirmation

    opt Connectivity is restored
      HealthWorker->>SyncService: Start synchronization
      SyncService->>OfflineCache: Fetch pending records
      OfflineCache-->>SyncService: Return pending records
      loop For each pending record
        SyncService->>Vaccination: Submit vaccination event
        Vaccination->>CentralDB: Save dose and observation
        CentralDB-->>Vaccination: Acknowledged
        Vaccination->>Vaccination: Calculate next due date
        Vaccination->>CentralDB: Update patient schedule
        alt Overdue
          Vaccination->>CentralDB: Flag patient as defaulter
        else On time
          Vaccination->>CentralDB: Clear defaulter flag
        end
      end
      Vaccination-->>SyncService: Synchronization succeeds
      SyncService->>OfflineCache: Clear synchronized records
      SyncService-->>HealthWorker: Sync complete
    end
