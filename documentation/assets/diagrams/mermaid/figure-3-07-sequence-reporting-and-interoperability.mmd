%%{init: {
  "theme": "base",
  "themeVariables": {
    "actorBkg": "#ffffff",
    "actorBorder": "#4d6fb8",
    "actorTextColor": "#2f3152",
    "signalColor": "#40455d",
    "signalTextColor": "#2f3152",
    "labelBoxBkgColor": "#eef4ff",
    "labelBoxBorderColor": "#8fa4d6",
    "labelTextColor": "#2f3152",
    "noteBkgColor": "#f8fbff",
    "noteBorderColor": "#c7d3f0",
    "sequenceNumberColor": "#2f3152",
    "fontFamily": "Arial, Helvetica, sans-serif"
  }
}}%%
sequenceDiagram
    autonumber
    actor Administrator
    participant Reporting as "Reporting Service"
    participant Interop as "Interoperability Service"
    participant FHIR as "FHIR Mapper"
    participant DHIS2 as "DHIS2 Platform (External)"
    participant CentralDB as "Central Database"

    Note over Administrator,CentralDB: FR18-FR21: Reporting and Interoperability
    Administrator->>Reporting: Generate monthly coverage report
    Reporting->>CentralDB: Query aggregated statistics
    CentralDB-->>Reporting: Raw data
    Reporting->>Reporting: Generate PDF/CSV
    Reporting-->>Administrator: Download file

    Note over Reporting,CentralDB: Scheduled interoperability synchronization
    Reporting->>Interop: Start weekly synchronization
    Interop->>CentralDB: Fetch unsynchronized records
    CentralDB-->>Interop: List of patient and immunization records
    loop For each record bundle
      Interop->>FHIR: Map records to FHIR resources
      FHIR->>FHIR: Map patient -> FHIR Patient
      FHIR->>FHIR: Map dose -> FHIR Immunization
      FHIR-->>Interop: Return FHIR bundle
      Interop->>DHIS2: POST /api/tracker (auth)
      alt Sync success
        DHIS2-->>Interop: 200 OK (import summary)
        Interop->>CentralDB: Update sync timestamp
      else Validation error
        DHIS2-->>Interop: 409 Conflict
        Interop->>CentralDB: Log validation error
      end
    end
    Interop-->>Reporting: Synchronization complete
