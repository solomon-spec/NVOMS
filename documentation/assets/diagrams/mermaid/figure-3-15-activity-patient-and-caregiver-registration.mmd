%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#5a6278",
    "primaryTextColor": "#2f3152",
    "secondaryColor": "#f8fbff",
    "tertiaryColor": "#eef4ff",
    "lineColor": "#40455d",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 34,
    "rankSpacing": 50,
    "htmlLabels": true
  }
}}%%
flowchart TD
    start([Start]) --> init["Health worker starts registration"]
    finish([End])
    init --> patient["Health worker enters patient demographics<br/>DOB, sex, location"]
    patient --> caregiver["Health worker enters caregiver details<br/>name, phone, relationship"]
    caregiver --> valid{"Input data is valid?"}
    valid -- Yes --> uid["System generates a unique patient identifier"]
    valid -- No --> correct["System prompts for corrections"] --> patient
    uid --> link["System links the patient and caregiver records"]
    link --> history["System initializes the digital vaccination history"]
    history --> offline{"Offline mode is enabled?"}
    offline -- Yes --> local["System stores the data locally and queues synchronization"]
    local --> restored{"Connectivity is restored?"}
    restored -- Yes --> sync["System synchronizes the data with the server"] --> finish
    restored -- No --> cont["Health worker continues working offline"] --> finish
    offline -- No --> save["System saves the records in the central database"]
    save --> confirm["System confirms registration and sends an SMS notification"] --> finish
