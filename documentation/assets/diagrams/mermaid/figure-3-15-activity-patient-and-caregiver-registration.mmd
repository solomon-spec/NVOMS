flowchart TD
    start([Start]) --> init["Healthcare worker initiates registration"]
    init --> patient["Enter patient demographics<br/>DOB, sex, location"]
    patient --> caregiver["Enter caregiver details<br/>name, phone, relationship"]
    caregiver --> valid{"Validate input data"}
    valid -- Yes --> uid["Generate unique persistent identifier (UID)"]
    valid -- No --> correct["Prompt for corrections"] --> patient
    uid --> link["Link patient to caregiver entity"]
    link --> history["Initialize digital vaccination history record"]
    history --> offline{"Offline mode?"}
    offline -- Yes --> local["Store locally and queue for sync"]
    local --> restored{"Connectivity restored?"}
    restored -- Yes --> sync["Synchronize data with server"] --> end([End])
    restored -- No --> cont["Continue offline"] --> end
    offline -- No --> save["Save to central database securely"]
    save --> confirm["Confirm registration and notify caregiver via SMS"] --> end
