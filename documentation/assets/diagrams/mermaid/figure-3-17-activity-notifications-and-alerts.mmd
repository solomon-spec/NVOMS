%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#eef0ff",
    "primaryBorderColor": "#b8b9ff",
    "primaryTextColor": "#2f3152",
    "secondaryColor": "#fff4b8",
    "tertiaryColor": "#ffffff",
    "lineColor": "#6c708f",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 28,
    "rankSpacing": 40,
    "htmlLabels": true
  }
}}%%
flowchart TD
    start([Start]) --> check["System checks vaccination schedule"]
    check --> upcoming{"Upcoming appointment?"}
    upcoming -- Yes --> remind["Send SMS reminder to caregiver"]
    remind --> success{"Delivery successful?"}
    success -- Yes --> log["Log notification sent"] --> end([End])
    success -- No --> retry["Retry SMS or queue for later"] --> end
    upcoming -- No --> missed["Check for missed appointments"]
    missed --> detected{"Missed appointment detected?"}
    detected -- Yes --> alert["Send follow-up SMS alert to caregiver"]
    alert --> delivered{"Delivery successful?"}
    delivered -- Yes --> monitor["Log alert sent and flag for monitoring"] --> end
    delivered -- No --> notify["Retry or notify health worker"] --> end
    detected -- No --> none["No action needed"] --> end
