%%{init: {
  "theme": "base",
  "themeVariables": {
    "actorBkg": "#ffffff",
    "actorBorder": "#4d6fb8",
    "actorTextColor": "#2f3152",
    "signalColor": "#40455d",
    "signalTextColor": "#2f3152",
    "labelBoxBkgColor": "#eef4ff",
    "labelBoxBorderColor": "#8fa4d6",
    "labelTextColor": "#2f3152",
    "noteBkgColor": "#f8fbff",
    "noteBorderColor": "#c7d3f0",
    "sequenceNumberColor": "#2f3152",
    "fontFamily": "Arial, Helvetica, sans-serif"
  }
}}%%
sequenceDiagram
    autonumber
    participant Scheduler as "System Scheduler"
    participant Notification as "Notification Service"
    participant CentralDB as "Central Database"
    participant Gateway as "SMS Gateway (External)"
    actor Caregiver

    Note over Scheduler,Gateway: FR12-FR13: Automated SMS Alerts
    Scheduler->>Notification: Trigger daily batch (00:00)
    par Fetch recipient groups
      Notification->>CentralDB: Query appointments due tomorrow
      CentralDB-->>Notification: List of reminder recipients
      Notification->>CentralDB: Query appointments missed by more than 48 hours
      CentralDB-->>Notification: List of defaulter recipients
    end
    loop For each caregiver record
      Notification->>Notification: Localize message template
      alt Reminder
        Notification->>Gateway: Send reminder SMS
      else Missed appointment alert
        Notification->>Gateway: Send missed-appointment alert
      end
      alt Gateway unavailable
        Gateway-->>Notification: 500 error
        Notification->>CentralDB: Queue retry record
        CentralDB-->>Notification: Retry queued
      else Accepted
        Gateway-->>Notification: 200 OK
        Gateway-->>Caregiver: Deliver SMS
      end
    end
    Notification-->>Scheduler: Batch job complete
