}}%%
flowchart LR
    classDef actor fill:#ffffff,stroke:#7e90b6,color:#2f3152,stroke-width:1px
    classDef module fill:#eef4ff,stroke:#4d6fb8,color:#24314f,stroke-width:1px
    classDef external fill:#ffffff,stroke:#8f79c8,color:#3f2d73,stroke-width:1px

    admin[Administrator]:::actor
    worker[Health Worker]:::actor
    official[Public Health Official]:::actor
    caregiver[Caregiver]:::actor
    userMgmt[User Management Module]:::module
    config[System Configuration Module]:::module
    registry[Patient Registry Module]:::module
    vaccination[Vaccination Tracking Module]:::module
    defaulter[Defaulter Monitoring Module]:::module
    notification[Notification Service]:::module
    analytics[Analytics Service]:::module
    prediction[Prediction Service]:::module
    reporting[Reporting Service]:::module
    interop[Interoperability Module]:::module

    dhis2[DHIS2]:::external
    fhir[FHIR Server]:::external
    sms[SMS Gateway]:::external
    weather[Weather API]:::external

    admin -->|1: manage users| userMgmt
    admin -->|2: configure settings| config
    worker -->|3: register patient and caregiver| registry
    registry -->|4: create vaccination schedule| vaccination
    worker -->|5: record dose and surveillance data| vaccination
    vaccination -->|6: update follow-up status| defaulter
    defaulter -->|7: schedule reminder or alert| notification
    notification -->|8: send SMS message| sms
    sms -->|9: deliver reminder or alert| caregiver
    official -->|10: request dashboard insights| analytics
    analytics -->|11: request outbreak prediction| prediction
    prediction -->|12: fetch environmental factors| weather
    prediction -->|13: return risk indicators| analytics
    admin -->|14: generate report| reporting
    official -->|15: review report| reporting
    reporting -->|16: prepare export bundle| interop
    interop -->|17: exchange standardized data| fhir
    interop -->|18: synchronize data with DHIS2| dhis2
