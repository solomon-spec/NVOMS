%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#79aefc",
    "primaryBorderColor": "#4987dd",
    "primaryTextColor": "#163867",
    "secondaryColor": "#ff79d8",
    "tertiaryColor": "#ffffff",
    "lineColor": "#686d89",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 34,
    "rankSpacing": 48,
