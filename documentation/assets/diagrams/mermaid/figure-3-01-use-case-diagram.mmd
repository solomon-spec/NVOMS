%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#5a6278",
    "primaryTextColor": "#2f3152",
    "secondaryColor": "#f8fbff",
    "tertiaryColor": "#eef4ff",
    "lineColor": "#40455d",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 30,
    "rankSpacing": 42,
    "htmlLabels": true
  }
}}%%
flowchart LR
    classDef actor fill:#ffffff,stroke:#7e90b6,color:#2f3152,stroke-width:1px
    classDef usecase fill:#eef4ff,stroke:#4d6fb8,color:#24314f,stroke-width:1px
    classDef external fill:#ffffff,stroke:#8f79c8,color:#3f2d73,stroke-width:1px
    classDef note fill:#f8fbff,stroke:#7e90b6,color:#2f3152,stroke-width:1px

    admin[Administrator]:::actor
    hw[Health Worker]:::actor
    caregiver[Caregiver]:::actor
    smsGateway[SMS Gateway]:::external
    dhis2[DHIS2]:::external
    official[Public Health Official]:::actor
    fhirNote["All exchanged health data shall conform to HL7 FHIR<br/>for Patient, Immunization, and Observation"]:::note

    subgraph system["System"]
        direction TB
        auth([Authenticate User]):::usecase
        manage([Manage User Accounts]):::usecase
        settings([Configure System Settings]):::usecase
        register([Register Patient]):::usecase
        viewRecord([View Patient<br/>Immunization Record]):::usecase
        recordDose([Record Vaccine<br/>Administration]):::usecase
        surveillance([Record Surveillance<br/>Data]):::usecase
        genSchedule([Generate Vaccination<br/>Schedule]):::usecase
        monitor([Monitor Vaccination<br/>Status]):::usecase
        identify([Identify Defaulters]):::usecase
        reminder([Send Vaccination<br/>Reminder]):::usecase
        missed([Send Missed<br/>Appointment Alert]):::usecase
        receiveReminder([Receive Vaccination<br/>Reminder SMS]):::usecase
        receiveMissed([Receive Missed<br/>Appointment Alert]):::usecase
        analytics([View Analytics<br/>Dashboard]):::usecase
        riskMap([View Outbreak<br/>Risk Map]):::usecase
        reports([Generate and Export<br/>Reports]):::usecase
        predict([Predict Disease<br/>Outbreak]):::usecase
        detect([Detect High-Defaulter<br/>Clusters]):::usecase
        share([Share Immunization<br/>Data with DHIS2]):::usecase
        exchange([Exchange Health Data<br/>using HL7 FHIR]):::usecase
    end

    admin --- auth
    admin --- manage
    admin --- settings
    admin --- reports

    hw --- auth
    hw --- register
    hw --- viewRecord
    hw --- recordDose
    hw --- surveillance
    hw --- monitor

    official --- auth
    official --- analytics
    official --- riskMap
    official --- reports

    caregiver --- receiveReminder
    caregiver --- receiveMissed
    smsGateway --- reminder
    smsGateway --- missed
    dhis2 --- share
    dhis2 --- exchange
    fhirNote --- exchange

    register -.->|<<include>>| genSchedule
    monitor -.->|<<include>>| identify
    genSchedule -.->|<<extend>>| reminder
    identify -.->|<<extend>>| missed
    monitor -.->|supports| detect
    predict -.->|feeds| analytics
    predict -.->|feeds| riskMap
