%%{init: {
  "theme": "base",
  "themeVariables": {
    "actorBkg": "#ffffff",
    "actorBorder": "#4d6fb8",
    "actorTextColor": "#2f3152",
    "signalColor": "#40455d",
    "signalTextColor": "#2f3152",
    "labelBoxBkgColor": "#eef4ff",
    "labelBoxBorderColor": "#8fa4d6",
    "labelTextColor": "#2f3152",
    "noteBkgColor": "#f8fbff",
    "noteBorderColor": "#c7d3f0",
    "sequenceNumberColor": "#2f3152",
    "fontFamily": "Arial, Helvetica, sans-serif"
  }
}}%%
sequenceDiagram
    autonumber
    actor Administrator
    actor HealthWorker as "Health Worker"
    participant WebPortal as "Web Portal"
    participant AuthService as "Auth Service"
    participant AccessControl as "Access Control"
    participant CentralDB as "Central Database"
    participant NotificationService as "Notification Service"

    rect rgb(255, 248, 180)
    Note over Administrator,CentralDB: FR1: Role-Based Account Creation
    Administrator->>WebPortal: Create account (role = Health Worker)
    WebPortal->>AuthService: POST /users
    AuthService->>AccessControl: Validate administrator permissions
    AccessControl-->>AuthService: Authorized
    AuthService->>CentralDB: Check whether the account already exists
    CentralDB-->>AuthService: Account not found
    AuthService->>AuthService: Hash temporary password (Argon2)
    AuthService->>CentralDB: Insert user record
    CentralDB-->>AuthService: User ID created
    AuthService-->>WebPortal: Success message
    WebPortal-->>Administrator: Display confirmation
    end

    rect rgb(255, 248, 180)
    Note over HealthWorker,CentralDB: FR2 and FR3: Secure Authentication and Password Recovery
    HealthWorker->>WebPortal: Enter credentials
    WebPortal->>AuthService: Login(email, password)
    AuthService->>CentralDB: Fetch password hash
    CentralDB-->>AuthService: Return hash
    alt Credentials valid
      AuthService->>AuthService: Generate JWT token
      AuthService-->>WebPortal: 200 OK + token
      WebPortal-->>HealthWorker: Redirect to dashboard
    else Invalid password
      AuthService-->>WebPortal: 401 Unauthorized
      WebPortal-->>HealthWorker: Show error "Invalid credentials"
    end
    opt FR3: Password recovery
      HealthWorker->>WebPortal: Request password reset
      WebPortal->>AuthService: Initiate reset flow
      AuthService->>CentralDB: Create password reset token
      CentralDB-->>AuthService: Token stored
      AuthService->>NotificationService: Send reset token
      NotificationService-->>HealthWorker: Deliver secure reset token
    end
    end
