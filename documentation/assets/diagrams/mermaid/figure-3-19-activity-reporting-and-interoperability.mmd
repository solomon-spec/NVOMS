%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#ffffff",
    "primaryBorderColor": "#5a6278",
    "primaryTextColor": "#2f3152",
    "secondaryColor": "#f8fbff",
    "tertiaryColor": "#eef4ff",
    "lineColor": "#40455d",
    "fontFamily": "Arial, Helvetica, sans-serif"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 34,
    "rankSpacing": 50,
    "htmlLabels": true
  }
}}%%
flowchart TD
    start([Start]) --> request["Authorized user requests a configurable report"]
    finish([End])
    request --> generate["System generates a report from aggregated data"]
    generate --> export{"Export format is specified?"}
    export -- Yes --> file["System exports the report in standard formats<br/>CSV, PDF"]
    export -- No --> dashboard["System displays the report in the dashboard"]
    file --> map["System maps the data to HL7 FHIR resources<br/>Patient, Immunization, Observation"]
    dashboard --> map
    map --> exchange["System exchanges the data with DHIS2 and partner platforms"]
    exchange --> ok{"Interoperability exchange succeeds?"}
    ok -- Yes --> log["System logs the exchange and audit trail"] --> finish
    ok -- No --> retry["System handles the error and retries the exchange"] --> finish
