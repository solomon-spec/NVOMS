stateDiagram-v2
    direction TB
    state "Idle Session" as IdleSession
    [*] --> Inactive: Administrator creates the account
    Inactive --> Active: User signs in and changes the password
    Active --> Inactive: User signs out or the session expires
    Active --> Locked: Three failed sign-in attempts occur
    Locked --> Inactive: Administrator unlocks the account
    Active --> Deleted: Administrator deletes the account

    state Active {
        [*] --> Idle
        Idle --> IdleSession: User performs a task
        IdleSession --> Idle: Task completes
    }
