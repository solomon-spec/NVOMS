////////////////////////////////////////////////////////////
// Paste this into https://dbdiagram.io to generate the ERD
////////////////////////////////////////////////////////////

Table administrative_units {
  unit_id uuid [pk]
  parent_unit_id uuid
  level varchar(20) [not null]
  code varchar(32) [not null, unique]
  name varchar(120) [not null]
  latitude decimal(9,6)
  longitude decimal(9,6)
  boundary_geojson jsonb
  is_active boolean [not null]
  created_at timestamptz [not null]
}

Table health_facilities {
  facility_id uuid [pk]
  unit_id uuid [not null]
  facility_code varchar(32) [not null, unique]
  facility_name varchar(160) [not null]
  facility_type varchar(40) [not null]
  dhis2_org_unit_code varchar(64)
  phone_number varchar(24)
  latitude decimal(9,6)
  longitude decimal(9,6)
  is_active boolean [not null]
  created_at timestamptz [not null]
}

Table roles {
  role_id uuid [pk]
  role_code varchar(40) [not null, unique]
  role_name varchar(80) [not null]
  description text
}

Table permissions {
  permission_id uuid [pk]
  permission_code varchar(60) [not null, unique]
  permission_name varchar(120) [not null]
  description text
}

Table role_permissions {
  role_id uuid [not null]
  permission_id uuid [not null]
}

Table users {
  user_id uuid [pk]
  role_id uuid [not null]
  assigned_facility_id uuid
  assigned_unit_id uuid
  full_name varchar(160) [not null]
  email varchar(160)
  phone_number varchar(24)
  password_hash text [not null]
  must_change_password boolean [not null]
  status varchar(20) [not null]
  failed_login_attempts int [not null]
  locked_until timestamptz
  preferred_language varchar(12)
  last_login_at timestamptz
  created_by_user_id uuid
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table user_sessions {
  session_id uuid [pk]
  user_id uuid [not null]
  jwt_id varchar(128) [not null, unique]
  client_ip varchar(64)
  user_agent text
  issued_at timestamptz [not null]
  expires_at timestamptz [not null]
  revoked_at timestamptz
}

Table password_reset_tokens {
  password_reset_token_id uuid [pk]
  user_id uuid [not null]
  token_hash text [not null, unique]
  delivery_channel varchar(12) [not null]
  expires_at timestamptz [not null]
  used_at timestamptz
  requested_at timestamptz [not null]
}

Table audit_logs {
  audit_log_id bigint [pk]
  actor_user_id uuid
  subsystem varchar(80) [not null]
  action_code varchar(80) [not null]
  entity_type varchar(80) [not null]
  entity_id uuid
  before_state jsonb
  after_state jsonb
  source_ip varchar(64)
  created_at timestamptz [not null]
}

Table system_settings {
  setting_id uuid [pk]
  facility_id uuid
  setting_scope varchar(20) [not null]
  setting_key varchar(120) [not null]
  setting_value jsonb [not null]
  is_encrypted boolean [not null]
  updated_by_user_id uuid
  updated_at timestamptz [not null]
}

Table caregivers {
  caregiver_id uuid [pk]
  full_name varchar(160) [not null]
  phone_number varchar(24) [not null]
  alternate_phone_number varchar(24)
  relationship_to_patient varchar(60) [not null]
  preferred_language varchar(12)
  residence_unit_id uuid
  address_line text
  status varchar(20) [not null]
  created_at timestamptz [not null]
}

Table patients {
  patient_id uuid [pk]
  uid varchar(40) [not null, unique]
  primary_caregiver_id uuid [not null]
  residence_unit_id uuid
  registered_facility_id uuid
  registered_by_user_id uuid
  first_name varchar(80) [not null]
  middle_name varchar(80)
  last_name varchar(80)
  sex varchar(12) [not null]
  date_of_birth date [not null]
  medical_exception_flag boolean [not null]
  duplicate_review_status varchar(24) [not null]
  status varchar(24) [not null]
  qr_code_value varchar(120)
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
}

Table patient_duplicate_cases {
  duplicate_case_id uuid [pk]
  candidate_patient_id uuid [not null]
  matched_patient_id uuid [not null]
  similarity_score decimal(5,4)
  review_status varchar(24) [not null]
  reviewed_by_user_id uuid
  reviewed_at timestamptz
  notes text
}

Table vaccine_definitions {
  vaccine_id uuid [pk]
  vaccine_code varchar(40) [not null, unique]
  vaccine_name varchar(120) [not null]
  target_disease varchar(80) [not null]
  dose_sequence int
  default_route varchar(40)
  default_site varchar(40)
  is_active boolean [not null]
}

Table epi_schedule_versions {
  schedule_version_id uuid [pk]
  version_name varchar(80) [not null, unique]
  effective_from date [not null]
  effective_to date
  status varchar(20) [not null]
  notes text
  created_by_user_id uuid
  created_at timestamptz [not null]
}

Table epi_schedule_rules {
  schedule_rule_id uuid [pk]
  schedule_version_id uuid [not null]
  vaccine_id uuid [not null]
  dose_label varchar(60) [not null]
  recommended_age_days int [not null]
  grace_period_days int [not null]
  defaulter_threshold_days int [not null]
  medical_exception_rule jsonb
  is_birth_dose boolean [not null]
  is_active boolean [not null]
}

Table vaccine_batches {
  vaccine_batch_id uuid [pk]
  vaccine_id uuid [not null]
  batch_number varchar(80) [not null, unique]
  manufacturer_name varchar(120)
  expiry_date date
  source_system varchar(80)
  is_valid boolean [not null]
  created_at timestamptz [not null]
}

Table patient_vaccination_schedules {
  patient_schedule_id uuid [pk]
  patient_id uuid [not null]
  schedule_rule_id uuid [not null]
  vaccine_id uuid [not null]
  due_date date [not null]
  status varchar(20) [not null]
  status_reason text
  generated_at timestamptz [not null]
  status_changed_at timestamptz [not null]
}

Table immunization_events {
  immunization_event_id uuid [pk]
  patient_id uuid [not null]
  patient_schedule_id uuid
  vaccine_id uuid [not null]
  vaccine_batch_id uuid
  administered_by_user_id uuid
  facility_id uuid
  administered_at timestamptz [not null]
  administration_route varchar(40)
  administration_site varchar(40)
  event_status varchar(24) [not null]
  source_channel varchar(12) [not null]
  local_client_record_id varchar(120)
  notes text
  created_at timestamptz [not null]
}

Table schedule_status_events {
  status_event_id uuid [pk]
  patient_schedule_id uuid [not null]
  from_status varchar(20)
  to_status varchar(20) [not null]
  changed_by_user_id uuid
  changed_by_process varchar(80)
  changed_at timestamptz [not null]
  reason text
}

Table patient_immunization_status {
  patient_id uuid [pk]
  next_due_date date
  current_status varchar(20) [not null]
  due_count int [not null]
  overdue_count int [not null]
  administered_count int [not null]
  is_zero_dose boolean [not null]
  last_evaluated_at timestamptz [not null]
}

Table surveillance_reports {
  surveillance_report_id uuid [pk]
  patient_id uuid [not null]
  facility_id uuid
  reported_by_user_id uuid
  surveillance_category varchar(20) [not null]
  condition_type varchar(80) [not null]
  disease_suspected varchar(80)
  onset_date date [not null]
  body_temperature_c decimal(4,1)
  severity varchar(12)
  follow_up_required boolean [not null]
  status varchar(20) [not null]
  fhir_observation_id varchar(120)
  notes text
  created_at timestamptz [not null]
}

Table surveillance_symptoms {
  surveillance_symptom_id uuid [pk]
  surveillance_report_id uuid [not null]
  symptom_code varchar(40) [not null]
  symptom_label varchar(120) [not null]
  is_present boolean [not null]
  observation_value varchar(120)
}

Table environmental_observations {
  environmental_observation_id uuid [pk]
  unit_id uuid [not null]
  observed_at timestamptz [not null]
  source_name varchar(80) [not null]
  rainfall_mm decimal(8,2)
  max_temp_c decimal(5,2)
  min_temp_c decimal(5,2)
  humidity_pct decimal(5,2)
  raw_payload jsonb
  ingested_at timestamptz [not null]
}

Table model_registry {
  model_id uuid [pk]
  model_name varchar(80) [not null]
  model_version varchar(40) [not null]
  disease_code varchar(40) [not null]
  status varchar(20) [not null]
  trained_at timestamptz
  feature_schema jsonb
  artifact_uri text
  notes text
}

Table prediction_runs {
  prediction_run_id uuid [pk]
  model_id uuid [not null]
  triggered_by_user_id uuid
  run_type varchar(20) [not null]
  source_window_start timestamptz
  source_window_end timestamptz
  status varchar(20) [not null]
  started_at timestamptz [not null]
  completed_at timestamptz
  error_message text
}

Table prediction_scores {
  prediction_score_id uuid [pk]
  prediction_run_id uuid [not null]
  unit_id uuid [not null]
  disease_code varchar(40) [not null]
  risk_probability decimal(5,4) [not null]
  risk_level varchar(20) [not null]
  silent_district_flag boolean [not null]
  coverage_rate decimal(6,2)
  dropout_rate decimal(6,2)
  zero_dose_count int
  rainfall_mm decimal(8,2)
  temperature_c decimal(5,2)
  contributing_factors jsonb
  created_at timestamptz [not null]
}

Table defaulter_clusters {
  defaulter_cluster_id uuid [pk]
  prediction_run_id uuid
  unit_id uuid [not null]
  cluster_type varchar(24) [not null]
  algorithm_name varchar(40) [not null]
  cluster_label varchar(80)
  defaulter_rate decimal(6,2)
  affected_patient_count int
  notes text
  created_at timestamptz [not null]
}

Table outbreak_alerts {
  outbreak_alert_id uuid [pk]
  unit_id uuid [not null]
  disease_code varchar(40) [not null]
  prediction_score_id uuid
  surveillance_report_id uuid
  alert_source varchar(20) [not null]
  risk_probability decimal(5,4)
  status varchar(20) [not null]
  triggered_at timestamptz [not null]
  verified_by_user_id uuid
  verified_at timestamptz
  notes text
}

Table message_templates {
  template_id uuid [pk]
  template_code varchar(60) [not null, unique]
  channel varchar(12) [not null]
  message_type varchar(24) [not null]
  language_code varchar(12) [not null]
  template_body text [not null]
  is_active boolean [not null]
}

Table sms_notifications {
  sms_notification_id uuid [pk]
  template_id uuid
  caregiver_id uuid [not null]
  patient_id uuid
  patient_schedule_id uuid
  outbreak_alert_id uuid
  notification_type varchar(24) [not null]
  phone_number varchar(24) [not null]
  language_code varchar(12) [not null]
  message_body text [not null]
  priority smallint [not null]
  status varchar(20) [not null]
  retry_count int [not null]
  last_error text
  gateway_message_id varchar(120)
  scheduled_for timestamptz [not null]
  sent_at timestamptz
  delivered_at timestamptz
  created_at timestamptz [not null]
}

Table notification_attempts {
  notification_attempt_id uuid [pk]
  sms_notification_id uuid [not null]
  attempt_number int [not null]
  attempted_at timestamptz [not null]
  gateway_status_code varchar(40)
  gateway_response text
  attempt_status varchar(20) [not null]
}

Table report_definitions {
  report_definition_id uuid [pk]
  report_code varchar(60) [not null, unique]
  report_name varchar(160) [not null]
  report_scope varchar(20) [not null]
  definition_spec jsonb
  default_parameters jsonb
  description text
}

Table generated_reports {
  generated_report_id uuid [pk]
  report_definition_id uuid [not null]
  requested_by_user_id uuid
  facility_id uuid
  unit_id uuid
  output_format varchar(10) [not null]
  generation_status varchar(20) [not null]
  parameter_payload jsonb
  file_uri text
  requested_at timestamptz [not null]
  completed_at timestamptz
}

Table integration_endpoints {
  endpoint_id uuid [pk]
  endpoint_type varchar(20) [not null]
  endpoint_name varchar(120) [not null]
  base_url text [not null]
  auth_type varchar(20) [not null]
  configuration jsonb [not null]
  is_active boolean [not null]
}

Table integration_jobs {
  integration_job_id uuid [pk]
  endpoint_id uuid [not null]
  job_type varchar(20) [not null]
  status varchar(20) [not null]
  started_at timestamptz [not null]
  completed_at timestamptz
  request_payload jsonb
  response_summary jsonb
  error_details text
}

Table dhis2_sync_batches {
  dhis2_sync_batch_id uuid [pk]
  integration_job_id uuid [not null]
  sync_scope varchar(20) [not null]
  records_attempted int [not null]
  records_imported int [not null]
  records_failed int [not null]
  import_summary jsonb
  started_at timestamptz [not null]
  completed_at timestamptz
}

Table dhis2_sync_items {
  dhis2_sync_item_id uuid [pk]
  dhis2_sync_batch_id uuid [not null]
  entity_type varchar(20) [not null]
  entity_id uuid
  org_unit_code varchar(64)
  sync_status varchar(20) [not null]
  error_message text
}

Table fhir_exchange_logs {
  fhir_exchange_log_id uuid [pk]
  integration_job_id uuid
  direction varchar(12) [not null]
  resource_type varchar(20) [not null]
  internal_entity_type varchar(24) [not null]
  internal_entity_id uuid
  external_resource_id varchar(120)
  exchange_status varchar(24) [not null]
  payload jsonb
  error_message text
  exchanged_at timestamptz [not null]
}

Table device_registrations {
  device_id uuid [pk]
  user_id uuid [not null]
  device_label varchar(120) [not null]
  platform varchar(40) [not null]
  app_version varchar(40)
  last_seen_at timestamptz
  status varchar(20) [not null]
}

Table sync_batches {
  sync_batch_id uuid [pk]
  device_id uuid [not null]
  user_id uuid [not null]
  submitted_at timestamptz [not null]
  acknowledged_at timestamptz
  status varchar(20) [not null]
  record_count int [not null]
  conflict_count int [not null]
}

Table sync_batch_items {
  sync_batch_item_id uuid [pk]
  sync_batch_id uuid [not null]
  entity_type varchar(24) [not null]
  operation_type varchar(12) [not null]
  client_record_id varchar(120) [not null]
  server_record_id uuid
  item_status varchar(20) [not null]
  conflict_reason text
  payload_checksum varchar(128)
  payload jsonb
}

Ref: administrative_units.parent_unit_id > administrative_units.unit_id
Ref: health_facilities.unit_id > administrative_units.unit_id
Ref: role_permissions.role_id > roles.role_id
Ref: role_permissions.permission_id > permissions.permission_id
Ref: users.role_id > roles.role_id
Ref: users.assigned_facility_id > health_facilities.facility_id
Ref: users.assigned_unit_id > administrative_units.unit_id
Ref: users.created_by_user_id > users.user_id
Ref: user_sessions.user_id > users.user_id
Ref: password_reset_tokens.user_id > users.user_id
Ref: audit_logs.actor_user_id > users.user_id
Ref: system_settings.facility_id > health_facilities.facility_id
Ref: system_settings.updated_by_user_id > users.user_id
Ref: caregivers.residence_unit_id > administrative_units.unit_id
Ref: patients.primary_caregiver_id > caregivers.caregiver_id
Ref: patients.residence_unit_id > administrative_units.unit_id
Ref: patients.registered_facility_id > health_facilities.facility_id
Ref: patients.registered_by_user_id > users.user_id
Ref: patient_duplicate_cases.candidate_patient_id > patients.patient_id
Ref: patient_duplicate_cases.matched_patient_id > patients.patient_id
Ref: patient_duplicate_cases.reviewed_by_user_id > users.user_id
Ref: epi_schedule_versions.created_by_user_id > users.user_id
Ref: epi_schedule_rules.schedule_version_id > epi_schedule_versions.schedule_version_id
Ref: epi_schedule_rules.vaccine_id > vaccine_definitions.vaccine_id
Ref: vaccine_batches.vaccine_id > vaccine_definitions.vaccine_id
Ref: patient_vaccination_schedules.patient_id > patients.patient_id
Ref: patient_vaccination_schedules.schedule_rule_id > epi_schedule_rules.schedule_rule_id
Ref: patient_vaccination_schedules.vaccine_id > vaccine_definitions.vaccine_id
Ref: immunization_events.patient_id > patients.patient_id
Ref: immunization_events.patient_schedule_id > patient_vaccination_schedules.patient_schedule_id
Ref: immunization_events.vaccine_id > vaccine_definitions.vaccine_id
Ref: immunization_events.vaccine_batch_id > vaccine_batches.vaccine_batch_id
Ref: immunization_events.administered_by_user_id > users.user_id
Ref: immunization_events.facility_id > health_facilities.facility_id
Ref: schedule_status_events.patient_schedule_id > patient_vaccination_schedules.patient_schedule_id
Ref: schedule_status_events.changed_by_user_id > users.user_id
Ref: patient_immunization_status.patient_id > patients.patient_id
Ref: surveillance_reports.patient_id > patients.patient_id
Ref: surveillance_reports.facility_id > health_facilities.facility_id
Ref: surveillance_reports.reported_by_user_id > users.user_id
Ref: surveillance_symptoms.surveillance_report_id > surveillance_reports.surveillance_report_id
Ref: environmental_observations.unit_id > administrative_units.unit_id
Ref: prediction_runs.model_id > model_registry.model_id
Ref: prediction_runs.triggered_by_user_id > users.user_id
Ref: prediction_scores.prediction_run_id > prediction_runs.prediction_run_id
Ref: prediction_scores.unit_id > administrative_units.unit_id
Ref: defaulter_clusters.prediction_run_id > prediction_runs.prediction_run_id
Ref: defaulter_clusters.unit_id > administrative_units.unit_id
Ref: outbreak_alerts.unit_id > administrative_units.unit_id
Ref: outbreak_alerts.prediction_score_id > prediction_scores.prediction_score_id
Ref: outbreak_alerts.surveillance_report_id > surveillance_reports.surveillance_report_id
Ref: outbreak_alerts.verified_by_user_id > users.user_id
Ref: sms_notifications.template_id > message_templates.template_id
Ref: sms_notifications.caregiver_id > caregivers.caregiver_id
Ref: sms_notifications.patient_id > patients.patient_id
Ref: sms_notifications.patient_schedule_id > patient_vaccination_schedules.patient_schedule_id
Ref: sms_notifications.outbreak_alert_id > outbreak_alerts.outbreak_alert_id
Ref: notification_attempts.sms_notification_id > sms_notifications.sms_notification_id
Ref: generated_reports.report_definition_id > report_definitions.report_definition_id
Ref: generated_reports.requested_by_user_id > users.user_id
Ref: generated_reports.facility_id > health_facilities.facility_id
Ref: generated_reports.unit_id > administrative_units.unit_id
Ref: integration_jobs.endpoint_id > integration_endpoints.endpoint_id
Ref: dhis2_sync_batches.integration_job_id > integration_jobs.integration_job_id
Ref: dhis2_sync_items.dhis2_sync_batch_id > dhis2_sync_batches.dhis2_sync_batch_id
Ref: fhir_exchange_logs.integration_job_id > integration_jobs.integration_job_id
Ref: device_registrations.user_id > users.user_id
Ref: sync_batches.device_id > device_registrations.device_id
Ref: sync_batches.user_id > users.user_id
Ref: sync_batch_items.sync_batch_id > sync_batches.sync_batch_id
